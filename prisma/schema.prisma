// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH // Tiền mặt → tự động APPROVED
  E_WALLET // Ví điện tử (GrabPay, MoMo...) → bắt đầu PENDING
}

enum TransactionStatus {
  PENDING // Chờ đối soát
  APPROVED // Đã xác nhận, tính vào thu nhập ròng
}

enum Category {
  // Thu nhập
  GRAB_BIKE
  GRAB_EXPRESS
  GRAB_CAR
  BE_BIKE
  BE_CAR
  XANH_SM
  OTHER_INCOME

  // Chi phí
  FUEL // Xăng xe
  MAINTENANCE // Bảo dưỡng
  INSURANCE // Bảo hiểm
  FOOD // Ăn uống
  OTHER_EXPENSE
}

model User {
  id           String   @id @default(uuid())
  phoneNumber  String   @unique
  fullName     String
  password     String
  balance      Int      @default(0) // Đơn vị: VNĐ (tránh Float)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions Transaction[]
}

model Transaction {
  id            String            @id @default(uuid())
  amount        Int // VNĐ, luôn dương — type xác định cộng hay trừ
  type          TransactionType
  category      Category
  paymentMethod PaymentMethod
  status        TransactionStatus @default(PENDING)
  description   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
